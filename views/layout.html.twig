<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WK Voetbal Finale 2026{% endblock %} - Stadion de Kuip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <link rel="stylesheet" href="/css/main.css">

    {% block styles %}{% endblock %}
</head>
<body>

<nav class="kuip-nav navbar{% if is_admin %} admin-bar{% endif %}">
    <div class="container">
        <a class="kuip-brand" href="/">DE KUIP · 2026</a>
        <div class="d-flex align-items-center gap-2">
            {% if is_admin %}
                <span class="wk-mono">Admin</span>
                <form action="/logout" method="post" class="m-0">
                    <button type="submit" class="wk-btn wk-btn-sm">Uitloggen</button>
                </form>
            {% elseif is_logged_in %}
                <a href="/profile" class="wk-btn wk-btn-sm">Mijn inschrijving</a>
                <form action="/logout" method="post" class="m-0">
                    <button type="submit" class="wk-btn wk-btn-sm wk-btn-ghost">Uitloggen</button>
                </form>
            {% else %}
                <a href="/login" class="wk-btn wk-btn-sm">Inloggen</a>
                <a href="/register" class="wk-btn wk-btn-sm wk-btn-primary">Ticket aanvragen →</a>
            {% endif %}
        </div>
    </div>
</nav>

<main class="container py-4">
    {% block content %}{% endblock %}
</main>

<footer class="kuip-footer">
    <div class="container text-center">
        <span class="wk-mono">&copy; 2026 Stadion de Kuip - WK Voetbal Finale</span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmDVMu18ekf33NAgQGmkfKXzMXu0"
        crossorigin="anonymous"></script>
</body>
</html>
